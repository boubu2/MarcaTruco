<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/backgroundColor">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Informar Nomes"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="32dp"
        android:textColor="@color/textColorPrimary"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_border_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jogador 1:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etNomeJogador1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome do Jogador 1"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/textColorPrimary"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jogador 2:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etNomeJogador2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome do Jogador 2"
                android:inputType="textPersonName"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/textColorPrimary"/>

            <Button
                android:id="@+id/btnConfirmar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirmar"
                android:backgroundTint="@color/buttonColor"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
