<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/backgroundColor">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Marcador de Truco"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:textColor="@color/textColorPrimary"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/card_border_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvNomeJogador1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jogador 1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pontos: "
                    android:textSize="16sp"
                    android:textColor="@color/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvPontuacaoJogador1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnJ1Mais1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+1"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ1Mais3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+3"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ1Mais6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+6"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ1Mais9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+9"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ1Mais12"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+12"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/card_border_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvNomeJogador2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jogador 2"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pontos: "
                    android:textSize="16sp"
                    android:textColor="@color/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvPontuacaoJogador2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnJ2Mais1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+1"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ2Mais3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+3"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ2Mais6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+6"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ2Mais9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+9"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnJ2Mais12"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+12"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/buttonColor"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnHistorico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Histórico de Jogadas"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnZerarHistorico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Zerar Histórico"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnInformarNomes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Informar Nomes"
        android:backgroundTint="@color/buttonColor"
        android:textColor="#FFFFFF"/>

</LinearLayout>
